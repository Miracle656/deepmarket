# Telegram bot token from @BotFather (https://t.me/BotFather → /newbot)
BOT_TOKEN=

# Hosting mode:
#   - WEBHOOK_DOMAIN set → bot runs in webhook mode behind an Express
#     server on $PORT (Render-friendly). Telegram pushes updates to
#     ${WEBHOOK_DOMAIN}/telegram-webhook. /health is exposed for
#     UptimeRobot pings.
#   - Unset (local dev) → bot uses long-polling. No HTTP server.
WEBHOOK_DOMAIN=

# Indexer URL (Spot YES/NO markets)
INDEXER_URL=http://localhost:3000

# DeepBook Predict server (oracles + positions)
PREDICT_SERVER_URL=https://predict-server.testnet.mystenlabs.com

# Predict object id for filtering oracles to OUR Predict instance
PREDICT_OBJECT_ID=0xc8736204d12f0a7277c86388a68bf8a194b0a14c5538ad13f22cbd8e2a38028a

# Frontend base URL — used to build deep-links inside alert keyboards
WEB_URL=http://localhost:5174

# Poll cadence (ms). Default 30s.
POLL_MS=30000

# Subscription store path. JSON file persisted between restarts.
STORE_PATH=./subs.json

# ─────────────────────────────────────────────────────────────────────────
# Trader / strategy
# ─────────────────────────────────────────────────────────────────────────
# Per-user custodial wallets are generated/imported by each Telegram user
# via the bot's UI (🤖 Bot trader → 🆕 Generate fresh / 📥 Import existing)
# and persisted in subs.json. There is no global bot wallet.
#
# Strategy is enabled per Telegram chat via the inline ▶️ Start strategy
# button — not via env var.

# Strategy params (rule-based fallback path; ignored when LLM agent runs):
# Mint UP when oracle.spot > strike + (tick_size × STRATEGY_BUFFER_TICKS).
# Each mint sizes the position so max payout = STRATEGY_QTY_USD (in USD).
STRATEGY_BUFFER_TICKS=3
STRATEGY_QTY_USD=0.5

# Strategy tick cadence (ms). Default 60s — separate from POLL_MS.
# NOTE: on hosts that sleep idle instances (Render free), this setInterval
# can't be trusted — drive the loop via the /tick endpoint below instead.
STRATEGY_TICK_MS=60000

# Shared secret to drive a strategy tick over HTTP: GET /tick?key=<secret>.
# Point a cron (cron-job.org / UptimeRobot) at it every 1-5 min so the loop
# runs reliably on free-tier hosts. Empty → /tick is disabled (403).
TICK_SECRET=

# DEMO ONLY — bypass the edge bar and force one small -EV mint each tick so the
# end-to-end flow is visible on demand (useful when the vault prices every table
# at ~100% implied). NEVER leave on for real trading. Off unless 'true'.
DEMO_MODE=false

# Sui RPC endpoint
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# ─────────────────────────────────────────────────────────────────────────
# Service fee (per-trade dUSDC cut sent to a treasury address)
# ─────────────────────────────────────────────────────────────────────────

# Sui address that receives the per-trade service fee. Leave empty to skip.
BOT_TREASURY_ADDRESS=

# Fee in basis points of the mint's cover amount (100 = 1%).
# Worked example: 100 bps on $0.50 cover = $0.005 fee.
BOT_FEE_BPS=100

# ─────────────────────────────────────────────────────────────────────────
# LLM agent (Claude) — replaces the rule-based strategy when ON
# ─────────────────────────────────────────────────────────────────────────

# Anthropic API key. Leave empty to fall back to the rule-based loop.
ANTHROPIC_API_KEY=

# Master switch — when false the rule loop runs even if the key is set.
AGENT_ENABLED=true

# Claude model id. Defaults to claude-opus-4-7 (Opus 4.7).
AGENT_MODEL=claude-opus-4-7

# Soft cap — agent stops minting after this many USD of new exposure
# per user per rolling hour. Backstop against runaway behavior.
AGENT_MAX_USD_PER_HOUR=5

# Per-user memory file (recent trades, P&L, agent notes). JSON.
# Designed so the backend can be swapped to Walrus later.
AGENT_MEMORY_PATH=./agent-memory.json

# ─────────────────────────────────────────────────────────────────────────
# MemWal — Walrus-backed semantic memory for the agent
# ─────────────────────────────────────────────────────────────────────────
# Each settled trade is written as a natural-language memory via the
# MemWal SDK. Before each decision the agent recalls the most relevant
# past memories and injects them into the prompt. Leave any of the
# first two empty to disable MemWal — the local JSON store still works.
#
# Get an account ID + delegate key at https://staging.memwal.ai
MEMWAL_ACCOUNT_ID=
MEMWAL_DELEGATE_KEY=
MEMWAL_SERVER_URL=https://relayer.staging.memwal.ai
MEMWAL_NAMESPACE=deepmarket-bot
MEMWAL_RECALL_LIMIT=5
